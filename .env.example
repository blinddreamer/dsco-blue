# D-SCO Bluesky Bot Configuration
# Copy this to .env and fill in your values

# Your Bluesky handle (e.g. dsco.bsky.social)
BLUESKY_HANDLE=

# App password from Bluesky Settings > App Passwords
BLUESKY_APP_PASSWORD=

# How often to check for new BRs (seconds, default 600 = 10 min)
POLL_INTERVAL=600

# Minimum number of pilots in a BR to post about it
MIN_PILOTS=20

# Minimum ISK destroyed to be worth posting (default 500M)
MIN_ISK_DESTROYED=500000000

# Minimum ISK efficiency % to count as a "win" (default 55%)
MIN_EFFICIENCY=55

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
